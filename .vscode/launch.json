  "version": "0.2.0",
  "configurations": [
    {
      "name": "desktop",
      "request": "launch",
      "type": "dart",
      "args": [
        "--no-enable-impeller"
      ]
    },
    {
      "name": "desktop (profile mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "args": [
        "--enable-impeller"
      ]
    },
    {
      "name": "desktop (release mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "args": [
        "--enable-impeller"
      ]
    }
  ]
}